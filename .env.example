# =============================================
# Experiment Base — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------
# HuggingFace (для скачивания датасетов)
# ---------------------------
# Токен: https://huggingface.co/settings/tokens
# Нужен если датасет приватный или требует согласия с условиями
HF_TOKEN=hf_...

# ---------------------------
# OpenRouter (для DR-систем и облачных моделей)
# ---------------------------
OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------
# SciSage academic retrieval
# ---------------------------
# Google Serper: https://serper.dev/
GOOGLE_SERPER_KEY=...

# ---------------------------
# Локальный сервер (DeepSeek или любой OpenAI-совместимый)
# ---------------------------
# URL локального API (по умолчанию: http://localhost:8000/v1)
LOCAL_API_BASE=http://localhost:8000/v1

# API-ключ для локального сервера (если не требуется — оставь пустым или "none")
LOCAL_API_KEY=none

# Имя модели на локальном сервере (используется при --local флаге)
LOCAL_MODEL=deepseek-chat

# ---------------------------
# Дополнительные ключи (если нужны отдельно от OpenRouter)
# ---------------------------
# OPENAI_API_KEY=sk-...
# PERPLEXITY_API_KEY=pplx-...
