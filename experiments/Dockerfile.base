# experiments/Dockerfile.base
# Базовый образ для всех экспериментов.
# Сборка: docker build -f experiments/Dockerfile.base -t thesis-base .
# (запускай из корня репозитория)

FROM python:3.11-slim

WORKDIR /app

# Системные зависимости
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl \
    && rm -rf /var/lib/apt/lists/*

# Python зависимости (кэшируются отдельным слоем)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Исходный код
COPY src/        ./src/
COPY configs/    ./configs/
COPY repos/SurveyForge/SurveyBench/ ./repos/SurveyForge/SurveyBench/

# Пустые папки для данных (монтируются снаружи)
RUN mkdir -p datasets results eval_results

# Переменные окружения (переопределяются через --env-file .env)
ENV OPENROUTER_API_KEY=""
ENV LOCAL_API_BASE="http://host.docker.internal:8000/v1"
ENV LOCAL_API_KEY="none"
ENV LOCAL_MODEL="deepseek-chat"
ENV HF_TOKEN=""
ENV PYTHONUNBUFFERED=1
